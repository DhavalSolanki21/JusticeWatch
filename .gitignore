# Git Hygiene - JusticeWatch

# Django Database
db.sqlite3
*.sqlite3

# Environments and Secrets
.env
.env.*
!.env.example
.venv/
venv/
env/
ENV/

# Python Cache
__pycache__/
*.py[cod]
*$py.class
*.pyo
.pytest_cache/

# Django Static & Media
backend/staticfiles/
backend/media/

# Node / React Frontend Dependencies & Builds
node_modules/
dist/
build/
.npm/
# package-lock.json is intentionally NOT ignored

# Editors / IDEs / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Machine Learning Data and Artifacts
# Option B: We commit generated model binaries using Git LFS
backend/ml_pipeline/data/
backend/ml_pipeline/artifacts/*.pkl
backend/ml_pipeline/artifacts/*.keras
backend/ml_pipeline/artifacts/*.h5

# Keep specific models tracked for inference
!backend/ml_pipeline/artifacts/duration_regressor.pkl
!backend/ml_pipeline/artifacts/disposal_classifier_rf.pkl
!backend/ml_pipeline/artifacts/disposal_classifier_dt.pkl
!backend/ml_pipeline/artifacts/disposal_classifier_knn.pkl
!backend/ml_pipeline/artifacts/disposal_nn_model.keras
!backend/ml_pipeline/artifacts/nn_scaler.pkl
!backend/ml_pipeline/artifacts/encoders.pkl
